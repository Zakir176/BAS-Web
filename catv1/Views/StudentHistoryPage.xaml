<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.StudentHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    Title="My History"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Header -->
        <Grid Padding="24,20,24,10" ColumnDefinitions="Auto, *, Auto">
            <Border
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="40"
                Stroke="{StaticResource GlassBorder}"
                StrokeShape="RoundRectangle 20"
                WidthRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Label FontFamily="MaterialIcons" Text="&#xe5c4;" TextColor="White" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label
                Grid.Column="1"
                HorizontalOptions="Center"
                Style="{StaticResource LabelHeader}"
                Text="My Attendance History"
                VerticalOptions="Center" />
        </Grid>

        <!-- Stats -->
        <Grid Grid.Row="1" Margin="24,16" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Style="{StaticResource StatCard}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Present" Style="{StaticResource LabelCaption}" HorizontalOptions="Center" />
                    <Label Text="{Binding TotalPresent}" FontAttributes="Bold" FontSize="24" TextColor="{StaticResource Success}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Absent" Style="{StaticResource LabelCaption}" HorizontalOptions="Center" />
                    <Label Text="{Binding TotalAbsent}" FontAttributes="Bold" FontSize="24" TextColor="{StaticResource Error}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- List -->
        <CollectionView Grid.Row="2" Margin="24,0" ItemsSource="{Binding AttendanceLogs}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                    <Label Text="No attendance history found." TextColor="{StaticResource Gray400}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12" Padding="16" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource GlassBorder}" StrokeShape="RoundRectangle 16">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <Label Text="{Binding SessionDate}" FontAttributes="Bold" TextColor="White" FontSize="16" />
                            <Label Grid.Row="1" Text="{Binding SectionId}" TextColor="{StaticResource Gray400}" FontSize="14" Margin="0,4,0,0" />
                            <Border Grid.Column="1" Grid.RowSpan="2" VerticalOptions="Center" Padding="12,6" StrokeShape="RoundRectangle 12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Present">
                                        <Setter Property="BackgroundColor" Value="#1A10B981" />
                                        <Setter Property="Stroke" Value="#3310B981" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Absent">
                                        <Setter Property="BackgroundColor" Value="#1AEF4444" />
                                        <Setter Property="Stroke" Value="#33EF4444" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Late">
                                        <Setter Property="BackgroundColor" Value="#1AF59E0B" />
                                        <Setter Property="Stroke" Value="#33F59E0B" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding Status}" FontAttributes="Bold" FontSize="12">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Present">
                                            <Setter Property="TextColor" Value="{StaticResource Success}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Absent">
                                            <Setter Property="TextColor" Value="{StaticResource Error}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Late">
                                            <Setter Property="TextColor" Value="{StaticResource Warning}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>

