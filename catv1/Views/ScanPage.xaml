<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:catv1.Converters"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
    Title="Scan ID"
    BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <converters:StatusColorConverter x:Key="StatusColorConverter" />
        <converters:StatusConverter x:Key="StatusConverter" />
    </ContentPage.Resources>

    <Grid>
        <Grid
            Padding="30"
            IsVisible="{Binding IsSetupVisible}"
            RowDefinitions="Auto, *, Auto">

            <!--  Header  -->
            <VerticalStackLayout Spacing="8">
                <Label Style="{StaticResource LabelHeader}" Text="New Session" />
                <Label
                    Style="{StaticResource LabelCaption}"
                    Text="Select class details to begin scanning."
                    TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Row="1"
                Spacing="32"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="COURSE"
                        TextColor="{StaticResource Secondary}" />
                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="60"
                        Stroke="{StaticResource GlassBorder}"
                        StrokeShape="RoundRectangle 16">
                        <Grid Padding="16,0" ColumnDefinitions="*, Auto">
                            <Picker
                                Title="Select a Course"
                                ItemsSource="{Binding Sections}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedSection}"
                                VerticalOptions="Center" />
                            <ActivityIndicator
                                Grid.Column="1"
                                IsRunning="{Binding IsBusy}"
                                HeightRequest="20"
                                WidthRequest="20"
                                Color="{StaticResource Primary}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!--  Date Selector  -->
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="DATE"
                        TextColor="{StaticResource Secondary}" />
                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="60"
                        Stroke="{StaticResource GlassBorder}"
                        StrokeShape="RoundRectangle 16">
                            <Grid Padding="16,0" ColumnDefinitions="Auto, *">
                                <Label FontFamily="MaterialIcons" Text="&#xe916;" TextColor="{StaticResource Gray400}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                <DatePicker
                                    Grid.Column="1"
                                    Date="{Binding SelectedDate}"
                                    Format="ddd, MMM dd yyyy"
                                    VerticalOptions="Center" />
                            </Grid>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <Button
                Grid.Row="2"
                Command="{Binding StartSessionCommand}"
                HeightRequest="56"
                Text="START SCANNING"
                IsVisible="{Binding IsNotBusy}" />

            <ActivityIndicator
                Grid.Row="2"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}"
                HeightRequest="50"
                HorizontalOptions="Center" />
        </Grid>


        <!--  SCANNING VIEW  -->
        <Grid IsVisible="{Binding IsSessionActive}" RowDefinitions="Auto, Auto, *">

            <!--  Top Bar  -->
            <Grid
                Padding="16,14"
                BackgroundColor="{StaticResource Surface}"
                ColumnDefinitions="Auto, *, Auto">

                <!--  Divider line at bottom  -->
                <BoxView
                    Grid.ColumnSpan="3"
                    HeightRequest="1"
                    BackgroundColor="{StaticResource GlassBorder}"
                    VerticalOptions="End" />

                <Border
                    BackgroundColor="#1F2937"
                    HeightRequest="38"
                    Stroke="{StaticResource GlassBorder}"
                    StrokeShape="RoundRectangle 19"
                    WidthRequest="38">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}" />
                    </Border.GestureRecognizers>
                    <Label FontFamily="MaterialIcons" Text="&#xe5c4;" TextColor="{StaticResource Gray200}" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        HorizontalOptions="Center"
                        TextColor="White"
                        Text="{Binding SelectedCourse}" />
                    <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label FontFamily="MaterialIcons" Text="&#xe916;" TextColor="{StaticResource Gray400}" FontSize="12" VerticalOptions="Center" />
                        <Label
                            HorizontalOptions="Center"
                            Style="{StaticResource LabelCaption}"
                            Text="{Binding DateDisplay}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!--  Session timer / camera icon  -->
                <Border
                    Grid.Column="2"
                    BackgroundColor="#1F2937"
                    HeightRequest="38"
                    Stroke="{StaticResource GlassBorder}"
                    StrokeShape="RoundRectangle 19"
                    WidthRequest="38">
                    <Label FontFamily="MaterialIcons" Text="&#xe3b0;" TextColor="{StaticResource Primary}" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

            <!--  Camera & Stats  -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="18" Spacing="16">

                    <!--  Camera Frame  -->
                    <Border
                        HeightRequest="260"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="0"
                        BackgroundColor="#0A0F1A">

                        <Grid>
                            <!--  Live camera feed  -->
                            <zxing:CameraBarcodeReaderView
                                x:Name="cameraBarcodeReaderView"
                                BarcodesDetected="CameraBarcodeReaderView_BarcodesDetected"
                                IsDetecting="False"
                                IsTorchOn="False" />

                            <!--  Dark vignette overlay  -->
                            <Border
                                BackgroundColor="#55000000"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20" />

                            <!--  Corner brackets — top-left  -->
                            <AbsoluteLayout>
                                <!--  TL horizontal  -->
                                <BoxView AbsoluteLayout.LayoutFlags="None"
                                         AbsoluteLayout.LayoutBounds="40,40,40,3"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />
                                <!--  TL vertical  -->
                                <BoxView AbsoluteLayout.LayoutFlags="None"
                                         AbsoluteLayout.LayoutBounds="40,40,3,40"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />

                                <!--  TR horizontal  -->
                                <BoxView AbsoluteLayout.LayoutFlags="PositionProportional"
                                         AbsoluteLayout.LayoutBounds="1,0,40,3"
                                         Margin="0,40,-40,0"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />
                                <!--  TR vertical  -->
                                <BoxView AbsoluteLayout.LayoutFlags="PositionProportional"
                                         AbsoluteLayout.LayoutBounds="1,0,3,40"
                                         Margin="0,40,0,0"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />

                                <!--  BL horizontal  -->
                                <BoxView AbsoluteLayout.LayoutFlags="PositionProportional"
                                         AbsoluteLayout.LayoutBounds="0,1,40,3"
                                         Margin="40,0,0,-40"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />
                                <!--  BL vertical  -->
                                <BoxView AbsoluteLayout.LayoutFlags="PositionProportional"
                                         AbsoluteLayout.LayoutBounds="0,1,3,40"
                                         Margin="40,0,0,0"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />

                                <!--  BR horizontal  -->
                                <BoxView AbsoluteLayout.LayoutFlags="PositionProportional"
                                         AbsoluteLayout.LayoutBounds="1,1,40,3"
                                         Margin="0,0,-40,-40"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />
                                <!--  BR vertical  -->
                                <BoxView AbsoluteLayout.LayoutFlags="PositionProportional"
                                         AbsoluteLayout.LayoutBounds="1,1,3,40"
                                         Margin="0,0,0,-40"
                                         BackgroundColor="{StaticResource Primary}"
                                         CornerRadius="2" />

                                <!--  Scan-line bar  -->
                                <BoxView
                                    x:Name="scanLine"
                                    AbsoluteLayout.LayoutFlags="SizeProportional"
                                    AbsoluteLayout.LayoutBounds="60,120,0.78,2"
                                    BackgroundColor="{StaticResource Primary}"
                                    Opacity="0.85"
                                    CornerRadius="1" />
                            </AbsoluteLayout>

                            <!--  Status pill  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="14,7"
                                BackgroundColor="#CC0F172A"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="1"
                                VerticalOptions="End">
                                <HorizontalStackLayout Spacing="8">
                                    <!--  Pulsing dot  -->
                                    <Ellipse
                                        Fill="{StaticResource Primary}"
                                        HeightRequest="7"
                                        WidthRequest="7"
                                        VerticalOptions="Center" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="11"
                                        Text="SCANNING ACTIVE"
                                        TextColor="{StaticResource Primary}"
                                        VerticalOptions="Center"
                                        CharacterSpacing="1.5" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </Border>

                    <!--  Toast (success or error)  -->
                    <Border
                        Padding="14,12"
                        BackgroundColor="{StaticResource Surface}"
                        IsVisible="{Binding ShowFeedback}"
                        Stroke="{Binding IsScanError, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Success'}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1.5">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                            <!--  Icon circle  -->
                            <Border
                                HeightRequest="38"
                                WidthRequest="38"
                                StrokeShape="RoundRectangle 19"
                                StrokeThickness="0"
                                BackgroundColor="{Binding IsScanError, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Success'}"
                                Opacity="0.15"
                                VerticalOptions="Center" />
                            <Label
                                FontFamily="MaterialIcons"
                                FontSize="20"
                                Text="{Binding IsScanError, Converter={StaticResource BooleanToString}, ConverterParameter='&#xe000;|&#xe86c;'}"
                                TextColor="{Binding IsScanError, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Success'}"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                Margin="9,0,0,0" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    CharacterSpacing="1"
                                    Text="{Binding IsScanError, Converter={StaticResource BooleanToString}, ConverterParameter='SCAN ERROR|ATTENDANCE LOGGED'}"
                                    TextColor="{Binding IsScanError, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Success'}" />
                                <Label
                                    FontSize="14"
                                    TextColor="White"
                                    FontAttributes="Bold">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="ScanFeedbackMessage" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>

                            <Button
                                Grid.Column="2"
                                BackgroundColor="{StaticResource GlassSelection}"
                                Command="{Binding UndoScanCommand}"
                                CornerRadius="14"
                                FontSize="11"
                                HeightRequest="30"
                                WidthRequest="52"
                                IsVisible="{Binding IsNotScanError}"
                                Text="UNDO"
                                TextColor="{StaticResource Gray200}" />
                        </Grid>
                    </Border>


                    <!--  Stats Cards  -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="10">
                                <HorizontalStackLayout Spacing="6">
                                    <Label FontFamily="MaterialIcons" Text="&#xe8d8;" FontSize="14" TextColor="{StaticResource Success}" VerticalOptions="Center" />
                                    <Label Style="{StaticResource LabelCaption}" Text="PRESENT" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="30"
                                        Text="{Binding PresentCount}"
                                        TextColor="{StaticResource Success}" />
                                    <Label
                                        Style="{StaticResource LabelCaption}"
                                        Text="{Binding TotalCount, StringFormat='/ {0}'}"
                                        VerticalOptions="End"
                                        Margin="0,0,0,4" />
                                </HorizontalStackLayout>
                                <ProgressBar Progress="{Binding PresentProgress}" ProgressColor="{StaticResource Success}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="10">
                                <HorizontalStackLayout Spacing="6">
                                    <Label FontFamily="MaterialIcons" Text="&#xe5cd;" FontSize="14" TextColor="{StaticResource Error}" VerticalOptions="Center" />
                                    <Label Style="{StaticResource LabelCaption}" Text="ABSENT" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="30"
                                        Text="{Binding AbsentCount}"
                                        TextColor="{StaticResource Error}" />
                                    <Label
                                        Style="{StaticResource LabelCaption}"
                                        Text="{Binding TotalCount, StringFormat='/ {0}'}"
                                        VerticalOptions="End"
                                        Margin="0,0,0,4" />
                                </HorizontalStackLayout>
                                <ProgressBar Progress="{Binding AbsentProgress}" ProgressColor="{StaticResource Error}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label FontFamily="MaterialIcons" Text="&#xe5db;" FontSize="12" TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                        <Label
                            Style="{StaticResource LabelCaption}"
                            Text="Scroll down to view roster &amp; override" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!--  Roster List  -->
            <Grid
                Grid.Row="2"
                BackgroundColor="{StaticResource Background}"
                RowDefinitions="Auto, *">
                <Border
                    Padding="16"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource GlassBorder}"
                    StrokeThickness="0,1,0,1">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label
                            FontAttributes="Bold"
                            Style="{StaticResource LabelCaption}"
                            Text="CLASS ROSTER"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="FILTERS"
                            TextColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

                <CollectionView Grid.Row="1" ItemsSource="{Binding Roster}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Padding="20,12"
                                BackgroundColor="{StaticResource Background}"
                                ColumnDefinitions="Auto, *, Auto">
                                <!--  Initials Avatar  -->
                                <Border
                                    BackgroundColor="{StaticResource Surface}"
                                    HeightRequest="44"
                                    Stroke="{StaticResource GlassBorder}"
                                    StrokeShape="RoundRectangle 22"
                                    WidthRequest="44">
                                    <Label
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        Text="{Binding Initials}"
                                        TextColor="{StaticResource Primary}"
                                        VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="16,0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontSize="14"
                                        Style="{StaticResource LabelHeader}"
                                        Text="{Binding Name}" />
                                    <Label Style="{StaticResource LabelCaption}" Text="{Binding Id}" />
                                </VerticalStackLayout>

                                <!--  Status Button  -->
                                <Button
                                    Grid.Column="2"
                                    Padding="12,0"
                                    BackgroundColor="{Binding IsPresent, Converter={StaticResource StatusConverter}, ConverterParameter='Color'}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ScanViewModel}}, Path=MarkStudentCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    HeightRequest="32"
                                    Text="{Binding IsPresent, Converter={StaticResource StatusConverter}, ConverterParameter='Text'}"
                                    TextColor="White" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--  Finish Button  -->
                <Button
                    Grid.Row="1"
                    Margin="24"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding FinishSessionCommand}"
                    CornerRadius="28"
                    HeightRequest="56"
                    HorizontalOptions="Center"
                    Text="FINISH SESSION"
                    VerticalOptions="End"
                    WidthRequest="220" />
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
