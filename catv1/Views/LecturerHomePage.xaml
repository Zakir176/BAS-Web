<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.LecturerHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    Title="Lecturer Dashboard"
    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Background}}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <!--  Background Image and Overlay  -->
        <Image
            Aspect="AspectFill"
            Opacity="0.15"
            Source="Resources/Images/lecture_room.png" />
        <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Background}}" Opacity="0.6" />

        <!--  Loading Overlay  -->
        <VerticalStackLayout
            HorizontalOptions="Center"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center">
            <ActivityIndicator
                HeightRequest="50"
                IsRunning="{Binding IsBusy}"
                WidthRequest="50"
                Color="#3B82F6" />
            <Label
                Margin="0,10,0,0"
                HorizontalOptions="Center"
                Text="Loading Dashboard..."
                TextColor="White" />
        </VerticalStackLayout>

        <Grid RowDefinitions="Auto, *">
            <!--  Header Section  -->
            <Grid Padding="20,40,20,10" ColumnDefinitions="Auto, *, Auto">
                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Surface}}"
                    HeightRequest="45"
                    StrokeShape="RoundRectangle 22.5"
                    StrokeThickness="0"
                    WidthRequest="45">
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="{Binding Initials}"
                        TextColor="White"
                        VerticalOptions="Center" />
                </Border>

                <HorizontalStackLayout
                    Grid.Column="2"
                    Spacing="18"
                    VerticalOptions="Center">
                    <!-- Theme Toggle -->
                    <Border
                        BackgroundColor="Transparent"
                        HeightRequest="36"
                        WidthRequest="36"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ThemeToggleCommand}" />
                        </Border.GestureRecognizers>
                        <Label FontFamily="MaterialIcons" Text="&#xe40a;" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <!-- Notifications -->
                    <Border
                        BackgroundColor="Transparent"
                        HeightRequest="36"
                        WidthRequest="36"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NotificationsCommand}" />
                        </Border.GestureRecognizers>
                        <Label FontFamily="MaterialIcons" Text="&#xe7f4;" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <!-- Logout -->
                    <Border
                        BackgroundColor="Transparent"
                        HeightRequest="36"
                        WidthRequest="36"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <Label FontFamily="MaterialIcons" Text="&#xe879;" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout
                    Padding="20"
                    IsClippedToBounds="False"
                    Spacing="25">
                    <!--  Refresh Control (Simplified)  -->
                    <Button
                        Margin="0,-20,0,0"
                        BackgroundColor="Transparent"
                        Command="{Binding RefreshCommand}"
                        FontSize="12"
                        HorizontalOptions="End"
                        Text="Refresh Data"
                        TextColor="#3B82F6" />

                    <!--  Welcome Text  -->
                    <VerticalStackLayout Spacing="5">
                        <Label FontAttributes="Bold" FontSize="28">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Welcome back, " TextColor="White" />
                                    <Span Text="{Binding Name, FallbackValue='Lecturer Steezy'}" TextColor="#3B82F6" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label
                            FontSize="14"
                            Text="{Binding SessionCountSubtitle}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                    </VerticalStackLayout>

                    <!--  Action Buttons  -->
                    <VerticalStackLayout Spacing="12">
                        <Button
                            BackgroundColor="#3B82F6"
                            Command="{Binding NewSessionCommand}"
                            CornerRadius="16"
                            FontAttributes="Bold"
                            HeightRequest="56"
                            Text="+ New Session"
                            TextColor="White" />

                        <Button
                            BackgroundColor="White"
                            Command="{Binding StartScanningCommand}"
                            CornerRadius="16"
                            FontAttributes="Bold"
                            HeightRequest="56"
                            Text="Start Scanning"
                            TextColor="#0F172A" />

                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Surface}}"
                            BorderColor="#334155"
                            BorderWidth="1"
                            Command="{Binding NewCourseCommand}"
                            CornerRadius="16"
                            FontAttributes="Bold"
                            HeightRequest="56"
                            Text="New Course"
                            TextColor="#3B82F6" />
                    </VerticalStackLayout>

                    <!--  Stats Cards  -->
                    <VerticalStackLayout Spacing="15">
                        <Border Style="{StaticResource StatCard}">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Style="{StaticResource LabelCaption}" Text="TOTAL COURSES" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="28"
                                        Text="{Binding TotalCourses}"
                                        TextColor="White" />
                                </VerticalStackLayout>
                                <Label FontFamily="MaterialIcons" Text="&#xe80c;" TextColor="#3B82F6" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" Grid.Column="1" Opacity="0.5" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Style="{StaticResource LabelCaption}" Text="ENROLLED STUDENTS" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="28"
                                        Text="{Binding EnrolledStudents}"
                                        TextColor="White" />
                                </VerticalStackLayout>
                                <Label FontFamily="MaterialIcons" Text="&#xe7fb;" TextColor="#10B981" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" Grid.Column="1" Opacity="0.5" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Style="{StaticResource LabelCaption}" Text="AVG. ATTENDANCE" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="28"
                                        Text="{Binding AvgAttendance}"
                                        TextColor="#3B82F6" />
                                </VerticalStackLayout>
                                <Label FontFamily="MaterialIcons" Text="&#xe8e5;" TextColor="#F59E0B" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" Grid.Column="1" Opacity="0.5" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!--  Course Attendance Overview (Chart)  -->
                    <VerticalStackLayout IsVisible="{Binding HasCourses}" Spacing="15">
                        <Label Style="{StaticResource LabelHeader}" Text="Course Attendance Overview" />
                        <Border Style="{StaticResource StatCard}">
                            <CollectionView HeightRequest="200" ItemsSource="{Binding CourseAttendanceData}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5" ColumnDefinitions="80, *">
                                            <Label
                                                Padding="0,0,10,0"
                                                FontSize="11"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding CourseName}"
                                                TextColor="White"
                                                VerticalOptions="Center" />
                                            <HorizontalStackLayout
                                                Grid.Column="1"
                                                Spacing="10"
                                                VerticalOptions="Center">
                                                <Border
                                                    BackgroundColor="{Binding Color}"
                                                    HeightRequest="12"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    WidthRequest="{Binding BarWidth}" />
                                                <Label
                                                    FontSize="10"
                                                    Text="{Binding AttendanceRate, StringFormat='{0:P0}'}"
                                                    TextColor="Gray"
                                                    VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout>

                    <!--  My Courses Section  -->
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                Text="My Courses"
                                TextColor="White" />
                            <Label
                                Grid.Column="1"
                                FontSize="14"
                                IsVisible="{Binding HasCourses}"
                                Text="See all"
                                TextColor="#3B82F6"
                                VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SeeAllCoursesCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!--  NEW: Courses List  -->
                        <CollectionView IsVisible="{Binding HasCourses}" ItemsSource="{Binding MyCourses}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatCard}">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <Border
                                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Surface}}"
                                                HeightRequest="40"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                WidthRequest="40">
                                                <Label FontFamily="MaterialIcons" Text="&#xe8ef;" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Margin="15,0"
                                                VerticalOptions="Center">
                                                <Label
                                                    FontAttributes="Bold"
                                                    Text="{Binding Name}"
                                                    TextColor="White" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding Code}"
                                                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                            </VerticalStackLayout>
                                            <Border
                                                Grid.Column="2"
                                                BackgroundColor="Transparent"
                                                HeightRequest="40"
                                                WidthRequest="40"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                StrokeThickness="0">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LecturerHomeViewModel}}, Path=DeleteCourseCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label
                                                    FontFamily="MaterialIcons"
                                                    Text="&#xe872;"
                                                    TextColor="#EF4444"
                                                    FontSize="20"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border
                            HeightRequest="150"
                            IsVisible="{Binding HasNoCourses}"
                            Style="{StaticResource StatCard}">
                            <VerticalStackLayout
                                HorizontalOptions="Center"
                                Spacing="10"
                                VerticalOptions="Center">
                                <Label FontFamily="MaterialIcons" Text="&#xe8ef;" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Label
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    Text="No Courses Created"
                                    TextColor="White" />
                                <Button
                                    BackgroundColor="#3B82F6"
                                    Command="{Binding CreateCourseCommand}"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    Text="Create Course" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!--  Session Roster Section  -->
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Style="{StaticResource LabelHeader}" Text="Active Session Roster" />
                            <HorizontalStackLayout
                                Grid.Column="1"
                                Spacing="10"
                                VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="5">
                                    <Ellipse
                                        Fill="{Binding IsSessionActive, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Tertiary'}"
                                        HeightRequest="8"
                                        VerticalOptions="Center"
                                        WidthRequest="8" />
                                    <Label
                                        FontSize="12"
                                        Text="{Binding IsSessionActive, Converter={StaticResource BooleanToString}, ConverterParameter='Disconnected|Live'}"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                </HorizontalStackLayout>
                                <Label
                                    FontSize="12"
                                    Text="{Binding ActiveSessionStats}"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                            </HorizontalStackLayout>
                        </Grid>

                        <!--  GAP 4: Search bar  -->
                        <SearchBar
                            x:Name="rosterSearch"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Surface}}"
                            CancelButtonColor="#3B82F6"
                            IsVisible="{Binding IsSessionActive}"
                            Placeholder="Search students..."
                            PlaceholderColor="#64748B"
                            Text="{Binding RosterSearchText}"
                            TextColor="White" />

                        <!--  GAP 4: Filter tabs  -->
                        <HorizontalStackLayout IsVisible="{Binding IsSessionActive}" Spacing="8">
                            <Button
                                Padding="12,0"
                                BackgroundColor="{Binding IsFilterAll, Converter={StaticResource BooleanToColor}, ConverterParameter='Primary|Surface'}"
                                Command="{Binding FilterAllCommand}"
                                CornerRadius="16"
                                FontAttributes="Bold"
                                FontSize="11"
                                HeightRequest="32"
                                Text="ALL"
                                TextColor="{Binding IsFilterAll, Converter={StaticResource BooleanToString}, ConverterParameter='White|#94A3B8'}" />
                            <Button
                                Padding="12,0"
                                BackgroundColor="{Binding IsFilterPresent, Converter={StaticResource BooleanToColor}, ConverterParameter='Tertiary|Surface'}"
                                Command="{Binding FilterPresentCommand}"
                                CornerRadius="16"
                                FontAttributes="Bold"
                                FontSize="11"
                                HeightRequest="32"
                                Text="PRESENT"
                                TextColor="{Binding IsFilterPresent, Converter={StaticResource BooleanToString}, ConverterParameter='White|#94A3B8'}" />
                            <Button
                                Padding="12,0"
                                BackgroundColor="{Binding IsFilterAbsent, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Surface'}"
                                Command="{Binding FilterAbsentCommand}"
                                CornerRadius="16"
                                FontAttributes="Bold"
                                FontSize="11"
                                HeightRequest="32"
                                Text="ABSENT"
                                TextColor="{Binding IsFilterAbsent, Converter={StaticResource BooleanToString}, ConverterParameter='White|#94A3B8'}" />
                        </HorizontalStackLayout>

                        <Border MinimumHeightRequest="180" Style="{StaticResource StatCard}">
                            <Grid>
                                <VerticalStackLayout
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding IsSessionActive, Converter={StaticResource InvertedBoolean}}"
                                    Spacing="15"
                                    VerticalOptions="Center">
                                    <Label FontFamily="MaterialIcons" Text="&#xe8b3;" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="44" HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Label
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        Text="No Active Session"
                                        TextColor="White" />
                                    <Label
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        Text="Roster visibility is only available during an active session."
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                </VerticalStackLayout>

                                <CollectionView IsVisible="{Binding IsSessionActive}" ItemsSource="{Binding FilteredSessionStudents}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,10" ColumnDefinitions="*, Auto">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        Text="{Binding FullName}"
                                                        TextColor="White" />
                                                    <Label
                                                        FontSize="10"
                                                        IsVisible="{Binding IsPresent}"
                                                        Text="{Binding ScanTime, StringFormat='At {0:hh:mm tt}'}"
                                                        TextColor="Gray" />
                                                    <Label
                                                        FontSize="10"
                                                        IsVisible="{Binding IsPresent, Converter={StaticResource InvertedBoolean}}"
                                                        Text="Not present yet"
                                                        TextColor="#EF4444" />
                                                </VerticalStackLayout>
                                                <Label
                                                    Grid.Column="1"
                                                    FontAttributes="Bold"
                                                    FontSize="18"
                                                    Text="{Binding IsPresent, Converter={StaticResource BooleanToString}, ConverterParameter='✕|✓'}"
                                                    TextColor="{Binding IsPresent, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Tertiary'}"
                                                    VerticalOptions="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>


                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
