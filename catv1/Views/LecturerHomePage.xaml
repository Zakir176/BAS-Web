<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.LecturerHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    Title="Lecturer Dashboard"
    BackgroundColor="#0F172A"
    Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Background Image and Overlay -->
        <Image 
            Aspect="AspectFill" 
            Opacity="0.15" 
            Source="Resources/Images/lecture_room.png" />
        <BoxView BackgroundColor="#0F172A" Opacity="0.6" />
        
        <!-- Loading Overlay -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#3B82F6" HeightRequest="50" WidthRequest="50" />
            <Label Text="Loading Dashboard..." TextColor="White" Margin="0,10,0,0" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Grid RowDefinitions="Auto, *">
            <!-- Header Section -->
            <Grid Padding="20,40,20,10" ColumnDefinitions="Auto, *, Auto">
                <Border
                    HeightRequest="45"
                    WidthRequest="45"
                    StrokeShape="RoundRectangle 22.5"
                    StrokeThickness="0"
                    BackgroundColor="#1E293B">
                    <Label Text="{Binding Initials}" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           FontSize="16" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>
                </Border>
                
                <HorizontalStackLayout Grid.Column="2" Spacing="15" VerticalOptions="Center">
                    <Label Text="☀️" FontSize="22" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ThemeToggleCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="📥" FontSize="22" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NotificationsCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="🚪" FontSize="22" VerticalOptions="Center" Margin="5,0,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20" Spacing="25" IsClippedToBounds="False">
                    <!-- Refresh Control (Simplified) -->
                    <Button Text="Refresh Data" Command="{Binding RefreshCommand}" 
                            BackgroundColor="Transparent" TextColor="#3B82F6" 
                            FontSize="12" HorizontalOptions="End" Margin="0,-20,0,0"/>

                    <!-- Welcome Text -->
                    <VerticalStackLayout Spacing="5">
                        <Label FontSize="28" FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Welcome back, " TextColor="White" />
                                    <Span Text="{Binding Name, FallbackValue='Lecturer Steezy'}" TextColor="#3B82F6" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Text="{Binding SessionCountSubtitle}" 
                               TextColor="#94A3B8" 
                               FontSize="14" />
                    </VerticalStackLayout>

                    <!-- Action Buttons -->
                    <VerticalStackLayout Spacing="12">
                        <Button Text="+ New Session" 
                                Command="{Binding NewSessionCommand}"
                                BackgroundColor="#3B82F6" 
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="56"
                                CornerRadius="16" />
                        
                        <Button Text="[||] Start Scanning" 
                                Command="{Binding StartScanningCommand}"
                                BackgroundColor="White" 
                                TextColor="#0F172A"
                                FontAttributes="Bold"
                                HeightRequest="56"
                                CornerRadius="16" />

                        <Button Text="New Course" 
                                Command="{Binding NewCourseCommand}"
                                BackgroundColor="#1E293B" 
                                TextColor="#3B82F6"
                                BorderColor="#334155"
                                BorderWidth="1"
                                FontAttributes="Bold"
                                HeightRequest="56"
                                CornerRadius="16" />
                    </VerticalStackLayout>

                    <!-- Stats Cards -->
                    <VerticalStackLayout Spacing="15">
                        <Border Style="{StaticResource StatCard}">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="TOTAL COURSES" Style="{StaticResource LabelCaption}" />
                                    <Label Text="{Binding TotalCourses}" FontSize="28" FontAttributes="Bold" TextColor="White" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="🎓" FontSize="24" Opacity="0.5" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="ENROLLED STUDENTS" Style="{StaticResource LabelCaption}" />
                                    <Label Text="{Binding EnrolledStudents}" FontSize="28" FontAttributes="Bold" TextColor="White" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="👥" FontSize="24" Opacity="0.5" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="AVG. ATTENDANCE" Style="{StaticResource LabelCaption}" />
                                    <Label Text="{Binding AvgAttendance}" FontSize="28" FontAttributes="Bold" TextColor="#3B82F6" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="📈" FontSize="24" Opacity="0.5" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Course Attendance Overview (Chart) -->
                    <VerticalStackLayout Spacing="15" IsVisible="{Binding HasCourses}">
                        <Label Text="Course Attendance Overview" Style="{StaticResource LabelHeader}" />
                        <Border Style="{StaticResource StatCard}">
                            <CollectionView ItemsSource="{Binding CourseAttendanceData}" HeightRequest="200">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,5" ColumnDefinitions="80, *">
                                            <Label Text="{Binding CourseName}" VerticalOptions="Center" FontSize="11" TextColor="White" Padding="0,0,10,0" LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                                <Border BackgroundColor="{Binding Color}" HeightRequest="12" WidthRequest="{Binding BarWidth}" StrokeShape="RoundRectangle 6" StrokeThickness="0" />
                                                <Label Text="{Binding AttendanceRate, StringFormat='{0:P0}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout>

                    <!-- My Courses Section -->
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="My Courses" FontSize="20" FontAttributes="Bold" TextColor="White" />
                            <Label Grid.Column="1" Text="See all" TextColor="#3B82F6" FontSize="14" VerticalOptions="Center" 
                                   IsVisible="{Binding HasCourses}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SeeAllCoursesCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        
                        <!-- NEW: Courses List -->
                        <CollectionView ItemsSource="{Binding MyCourses}" IsVisible="{Binding HasCourses}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatCard}">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <Border BackgroundColor="#1E293B" HeightRequest="40" WidthRequest="40" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                                <Label Text="📚" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="White" />
                                                <Label Text="{Binding Code}" FontSize="12" TextColor="#94A3B8" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="→" TextColor="#3B82F6" FontSize="20" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border Style="{StaticResource StatCard}" HeightRequest="150" IsVisible="{Binding HasNoCourses}">
                             <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                                <Label Text="📚" FontSize="30" HorizontalOptions="Center" />
                                <Label Text="No Courses Created" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                                <Button Text="Create Course" 
                                        Command="{Binding CreateCourseCommand}"
                                        BackgroundColor="#3B82F6" 
                                        CornerRadius="10" 
                                        HeightRequest="40" />
                             </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Session Roster Section -->
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Active Session Roster" Style="{StaticResource LabelHeader}" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="5">
                                    <Ellipse Fill="{Binding IsSessionActive, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Tertiary'}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                                    <Label Text="{Binding IsSessionActive, Converter={StaticResource BooleanToString}, ConverterParameter='Disconnected|Live'}" FontSize="12" TextColor="#94A3B8" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding ActiveSessionStats}" FontSize="12" TextColor="#94A3B8" />
                            </HorizontalStackLayout>
                        </Grid>

                        <Border Style="{StaticResource StatCard}" MinHeightRequest="180">
                            <Grid>
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15" IsVisible="{Binding IsSessionActive, Converter={StaticResource InvertedBoolean}}">
                                    <Label Text="📷" FontSize="40" HorizontalOptions="Center" />
                                    <Label Text="No Active Session" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                                    <Label Text="Roster visibility is only available during an active session." 
                                           TextColor="#94A3B8" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>

                                <CollectionView ItemsSource="{Binding ActiveSessionStudents}" IsVisible="{Binding IsSessionActive}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,10" ColumnDefinitions="*, Auto">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding FullName}" FontAttributes="Bold" TextColor="White" />
                                                    <Label Text="{Binding ScanTime, StringFormat='At {0:hh:mm tt}'}" FontSize="10" TextColor="Gray" IsVisible="{Binding IsPresent}" />
                                                    <Label Text="Not present yet" FontSize="10" TextColor="#EF4444" IsVisible="{Binding IsPresent, Converter={StaticResource InvertedBoolean}}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1" Text="{Binding IsPresent, Converter={StaticResource BooleanToString}, ConverterParameter='✕|✓'}" 
                                                       TextColor="{Binding IsPresent, Converter={StaticResource BooleanToColor}, ConverterParameter='Error|Tertiary'}"
                                                       FontSize="18" VerticalOptions="Center" FontAttributes="Bold" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>