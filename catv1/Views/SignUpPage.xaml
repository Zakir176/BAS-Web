<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.SignUpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    Title="Sign Up"
    BackgroundColor="{StaticResource Background}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <!--  Background Image with Overlay  -->
        <Image
            Aspect="AspectFill"
            Opacity="0.3"
            Source="Resources/Images/lecture_room.png" />

        <BoxView Opacity="0.6" Color="{StaticResource Background}" />

        <ScrollView>
            <VerticalStackLayout
                Padding="30"
                Spacing="32"
                VerticalOptions="FillAndExpand">

                <!--  Header Section  -->
                <VerticalStackLayout Margin="0,20,0,0" Spacing="12">
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource LabelHeader}"
                        Text="Create Account" />
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource LabelCaption}"
                        Text="Join the Smart Attendance System" />
                </VerticalStackLayout>

                <!--  Sign Up Card  -->
                <Border Margin="0,0,0,20" Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="28">

                        <!--  Role Switcher  -->
                        <Border
                            BackgroundColor="{StaticResource Surface}"
                            HeightRequest="56"
                            HorizontalOptions="Center"
                            Stroke="{StaticResource GlassBorder}"
                            StrokeShape="RoundRectangle 28"
                            WidthRequest="280">
                            <Grid ColumnDefinitions="*,*">
                                <Border
                                    Margin="4"
                                    BackgroundColor="{Binding IsStudent, Converter={StaticResource BoolToColorConverter}}"
                                    StrokeShape="RoundRectangle 24"
                                    StrokeThickness="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetRoleCommand}" CommandParameter="Student" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        Text="Student"
                                        TextColor="{Binding IsStudent, Converter={StaticResource BoolToInverseTextColorConverter}}"
                                        VerticalOptions="Center" />
                                </Border>
                                <Border
                                    Grid.Column="1"
                                    Margin="4"
                                    BackgroundColor="{Binding IsLecturer, Converter={StaticResource BoolToColorConverter}}"
                                    StrokeShape="RoundRectangle 24"
                                    StrokeThickness="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetRoleCommand}" CommandParameter="Lecturer" />
                                    </Border.GestureRecognizers>
                                    <Label
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        Text="Lecturer"
                                        TextColor="{Binding IsLecturer, Converter={StaticResource BoolToInverseTextColorConverter}}"
                                        VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Label
                            FontSize="18"
                            HorizontalOptions="Center"
                            Style="{StaticResource LabelHeader}"
                            Text="{Binding SignUpTitle}" />

                        <!--  Input Fields  -->
                        <VerticalStackLayout Spacing="16">
                            <!--  Name Field  -->
                            <Border
                                Padding="16,0"
                                BackgroundColor="{StaticResource Surface}"
                                HeightRequest="56"
                                Stroke="{StaticResource GlassBorder}"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="40, *">
                                    <Path
                                        Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                        Fill="{StaticResource PrimaryLight}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                    <Entry
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Placeholder="Full Name"
                                        Text="{Binding FullName}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <!--  Email Field  -->
                            <Border
                                Padding="16,0"
                                BackgroundColor="{StaticResource Surface}"
                                HeightRequest="56"
                                Stroke="{StaticResource GlassBorder}"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="40, *">
                                    <Path
                                        Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
                                        Fill="{StaticResource PrimaryLight}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                    <Entry
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Keyboard="Email"
                                        Placeholder="Email Address"
                                        Text="{Binding Email}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <!--  ID Field  -->
                            <Border
                                Padding="16,0"
                                BackgroundColor="{StaticResource Surface}"
                                HeightRequest="56"
                                IsVisible="{Binding IsStudent}"
                                Stroke="{StaticResource GlassBorder}"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="40, *">
                                    <Path
                                        Data="M22,3H2C0.91,3.04 0.04,3.91 0,5V19C0.04,20.09 0.91,20.96 2,21H22C23.09,20.96 23.96,20.09 24,19V5C23.96,3.91 23.09,3.04 22,3M22,19H2V5H22V19M14,17V15.75C14,14.09 10.66,13.25 9,13.25C7.34,13.25 4,14.09 4,15.75V17H14M9,7A2.5,2.5 0 0,1 11.5,9.5A2.5,2.5 0 0,1 9,12A2.5,2.5 0 0,1 6.5,9.5A2.5,2.5 0 0,1 9,7M19,17H16V15H19V17M19,13H16V11H19V13M19,9H16V7H19V9Z"
                                        Fill="{StaticResource PrimaryLight}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                    <Entry
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Placeholder="{Binding IdPlaceholder}"
                                        Text="{Binding Id}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>

                                <!--  Department/Class Field  -->
                            <Border
                                Padding="16,0"
                                BackgroundColor="{StaticResource Surface}"
                                HeightRequest="56"
                                Stroke="{StaticResource GlassBorder}"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="40, *">
                                    <Path
                                        Data="M12,7V3H2V21H22V7H12M6,19H4V17H6V19M6,15H4V13H6V15M6,11H4V9H6V11M6,7H4V5H6V7M10,19H8V17H10V19M10,15H8V13H10V15M10,11H8V9H10V11M10,7H8V5H10V7M20,19H12V17H14V15H12V13H14V11H12V9H20V19M18,11H16V13H18V11M18,15H16V17H18V15Z"
                                        Fill="{StaticResource PrimaryLight}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                    <!-- GAP 8: Replaced free-text Entry with Picker -->
                                    <Picker
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Title="{Binding DeptPlaceholder}"
                                        ItemsSource="{Binding Departments}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedDepartment}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <!--  Password Field  -->
                            <Border
                                Padding="16,0"
                                BackgroundColor="{StaticResource Surface}"
                                HeightRequest="56"
                                Stroke="{StaticResource GlassBorder}"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="40, *, 40">
                                    <Path
                                        Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                        Fill="{StaticResource PrimaryLight}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                    <Entry
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        IsPassword="{Binding IsPassword}"
                                        Placeholder="Password"
                                        Text="{Binding Password}"
                                        VerticalOptions="Center" />
                                    <Border
                                        Grid.Column="2"
                                        BackgroundColor="Transparent"
                                        HeightRequest="40"
                                        WidthRequest="40">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding TogglePasswordCommand}" />
                                        </Border.GestureRecognizers>
                                        <Path
                                            Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                            Fill="{StaticResource Gray400}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            WidthRequest="18"
                                            HeightRequest="18" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!--  Confirm Password Field  -->
                            <Border
                                Padding="16,0"
                                BackgroundColor="{StaticResource Surface}"
                                HeightRequest="56"
                                Stroke="{StaticResource GlassBorder}"
                                StrokeShape="RoundRectangle 16">
                                <Grid ColumnDefinitions="40, *">
                                    <Path
                                        Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                        Fill="{StaticResource PrimaryLight}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                    <Entry
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        IsPassword="{Binding IsPassword}"
                                        Placeholder="Confirm Password"
                                        Text="{Binding ConfirmPassword}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!--  Action Section  -->
                        <VerticalStackLayout Spacing="24">
                            <Button
                                Command="{Binding SignUpCommand}"
                                HeightRequest="56"
                                IsEnabled="{Binding IsNotBusy}"
                                Text="Create Account" />

                            <Label HorizontalOptions="Center" VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Style="{StaticResource LabelCaption}" Text="Already have an account? " />
                                        <Span
                                            FontAttributes="Bold"
                                            Style="{StaticResource LabelCaption}"
                                            Text="Login here"
                                            TextColor="{StaticResource Primary}">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding LoginCommand}" />
                                            </Span.GestureRecognizers>
                                        </Span>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!--  Footer Info  -->
                <Label
                    HorizontalOptions="Center"
                    Style="{StaticResource LabelCaption}"
                    Text="Version 1.0.0 • Verified Secure"
                    TextColor="{StaticResource Gray500}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
