<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.StudentHomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    Title="Student Detail"
    BackgroundColor="#0F172A"
    Shell.NavBarIsVisible="False">

    <Grid>
        <!--  Blurred Bg Image  -->
        <Image
            Aspect="AspectFill"
            Opacity="0.2"
            Source="Resources/Images/lecture_room.png" />
        <BoxView BackgroundColor="#0F172A" Opacity="0.5" />

        <Grid RowDefinitions="Auto, *">
            <!--  Header  -->
            <Grid Padding="20,20,20,10" ColumnDefinitions="Auto, *, Auto, Auto">
                <!-- Back/Logout Button -->
                <Border
                    BackgroundColor="#1E293B"
                    HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    WidthRequest="40">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutClicked" />
                    </Border.GestureRecognizers>
                    <Path
                        Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                        Fill="White"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="18"
                        HeightRequest="18" />
                </Border>

                <Label
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="Student Dashboard"
                    TextColor="White"
                    VerticalOptions="Center" />

                <!-- Notifications Button -->
                <Border
                    Grid.Column="2"
                    Margin="0,0,12,0"
                    BackgroundColor="#1E293B"
                    HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    WidthRequest="40">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NotificationsCommand}" />
                    </Border.GestureRecognizers>
                    <Path
                        Data="M21,19V20H3V19L5,17V11C5,7.9 7.03,5.17 10,4.29C10,4.19 10,4.1 10,4A2,2 0 0,1 12,2A2,2 0 0,1 14,4C14,4.1 14,4.19 14,4.29C16.97,5.17 19,7.9 19,11V17L21,19M14,21A2,2 0 0,1 12,23A2,2 0 0,1 10,21"
                        Fill="#94A3B8"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="18"
                        HeightRequest="18" />
                </Border>

                <!-- Settings Button -->
                <Border
                    Grid.Column="3"
                    BackgroundColor="#1E293B"
                    HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    WidthRequest="40">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SettingsCommand}" />
                    </Border.GestureRecognizers>
                    <Path
                        Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                        Fill="#94A3B8"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="18"
                        HeightRequest="18" />
                </Border>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20" Spacing="20">
                    <!--  Banner Section  -->
                    <Border
                        Padding="25"
                        StrokeShape="RoundRectangle 25"
                        StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0.1" /> <!-- Blue 600 -->
                                <GradientStop Color="#1E40AF" Offset="1.0" /> <!-- Blue 800 -->
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="15">
                            <Border
                                Padding="10,4"
                                BackgroundColor="#33FFFFFF"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="STUDENT PORTAL"
                                    TextColor="White" />
                            </Border>
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                LineHeight="1.1"
                                TextColor="White">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Welcome back, " />
                                        <Span FontAttributes="Bold" Text="{Binding Name}" />
                                        <Span Text="!" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label
                                FontSize="14"
                                Opacity="0.8"
                                Text="Your academic journey is looking great. Keep up the strong momentum!"
                                TextColor="White" />
                            <HorizontalStackLayout Spacing="10">
                                <Button
                                    BackgroundColor="White"
                                    Command="{Binding ShowIdCardCommand}"
                                    CornerRadius="12"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    HeightRequest="40"
                                    Text="Show ID Card"
                                    TextColor="#2563EB" />
                                <Button
                                    BackgroundColor="#33FFFFFF"
                                    Command="{Binding ViewReportsCommand}"
                                    CornerRadius="12"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    HeightRequest="40"
                                    Text="View Reports"
                                    TextColor="White" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stats Overview Section -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" RowDefinitions="Auto, Auto" RowSpacing="15">
                        <!--  Attendance Ratio (Donut Chart)  -->
                        <Border Grid.RowSpan="2" Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                                <Label FontAttributes="Bold" FontSize="14" HorizontalOptions="Center" Text="Attendance Ratio" TextColor="White" />
                                <Grid HeightRequest="120" WidthRequest="120">
                                    <Ellipse Stroke="#1F2937" StrokeThickness="10" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Ellipse Stroke="#10B981" StrokeThickness="10" HorizontalOptions="Center" VerticalOptions="Center"
                                             StrokeDashArray="100, 0" StrokeDashOffset="0" 
                                             IsVisible="{Binding AttendancePercentage, Converter={StaticResource GreaterThanZero}}"/>
                                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label Text="{Binding AttendanceDisplay}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White"/>
                                        <Label Text="OVERALL" FontSize="8" TextColor="Gray" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Grid>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                                    <HorizontalStackLayout Spacing="3">
                                        <BoxView BackgroundColor="#10B981" CornerRadius="2" HeightRequest="6" WidthRequest="6" VerticalOptions="Center"/>
                                        <Label Text="Present" FontSize="9" TextColor="Gray"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="3">
                                        <BoxView BackgroundColor="#EF4444" CornerRadius="2" HeightRequest="6" WidthRequest="6" VerticalOptions="Center"/>
                                        <Label Text="Absent" FontSize="9" TextColor="Gray"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Days Present KPI -->
                        <Border Grid.Column="1" Style="{StaticResource StatCard}">
                            <HorizontalStackLayout Spacing="15">
                                <Border
                                    BackgroundColor="#0D2F1F"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    VerticalOptions="Center">
                                    <Path
                                        Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"
                                        Fill="#10B981"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="16"
                                        HeightRequest="16" />
                                </Border>
                                <VerticalStackLayout>
                                    <Label Text="{Binding DaysPresent}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                                    <Label Text="DAYS PRESENT" FontSize="9" TextColor="Gray" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Days Absent KPI -->
                        <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource StatCard}">
                            <HorizontalStackLayout Spacing="15">
                                <Border
                                    BackgroundColor="#2F1212"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    VerticalOptions="Center">
                                    <Path
                                        Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                        Fill="#EF4444"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="16"
                                        HeightRequest="16" />
                                </Border>
                                <VerticalStackLayout>
                                    <Label Text="{Binding DaysAbsent}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                                    <Label Text="DAYS ABSENT" FontSize="9" TextColor="Gray" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!--  Current Streak  -->
                    <Border Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Current Streak" FontSize="12" TextColor="Gray" FontAttributes="Bold"/>
                            <HorizontalStackLayout Spacing="15">
                                <Border
                                    BackgroundColor="#2F1E0A"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    VerticalOptions="Center">
                                    <Path
                                        Data="M16,6L18.29,8.29L13.41,13.17L9.41,9.17L2,16.59L3.41,18L9.41,12L13.41,16L19.71,9.71L22,12V6H16Z"
                                        Fill="#F59E0B"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="18"
                                        HeightRequest="18" />
                                </Border>
                                <Label Text="Active" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                                <Border BackgroundColor="#1E293B" HeightRequest="8" WidthRequest="100" StrokeShape="RoundRectangle 4" StrokeThickness="0" VerticalOptions="Center">
                                    <BoxView BackgroundColor="#3B82F6" WidthRequest="{Binding StreakProgress, Converter={StaticResource PercentageToWidth}, ConverterParameter=100}" HorizontalOptions="Start"/>
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!--  Attendance Heatmap (Restyled)  -->
                    <Border Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label FontAttributes="Bold" FontSize="16" Text="Attendance Heatmap" TextColor="White" />
                                <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                        <Border BackgroundColor="#1F2937" HeightRequest="30" WidthRequest="30" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                                            </Border.GestureRecognizers>
                                            <Path
                                                Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z"
                                                Fill="White"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                WidthRequest="16"
                                                HeightRequest="16" />
                                        </Border>
                                        <Border BackgroundColor="#1F2937" HeightRequest="30" WidthRequest="30" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                                            </Border.GestureRecognizers>
                                            <Path
                                                Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                                Fill="White"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                WidthRequest="16"
                                                HeightRequest="16" />
                                        </Border>
                                </HorizontalStackLayout>
                            </Grid>

                            <Label Text="{Binding CurrentMonthYear}" FontSize="12" TextColor="Gray" Margin="0,-5,0,0"/>

                            <!--  Calendar Headers  -->
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,5">
                                <Label Grid.Column="0" Text="S" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                                <Label Grid.Column="1" Text="M" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                                <Label Grid.Column="2" Text="T" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                                <Label Grid.Column="3" Text="W" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                                <Label Grid.Column="4" Text="T" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                                <Label Grid.Column="5" Text="F" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                                <Label Grid.Column="6" Text="S" HorizontalOptions="Center" FontSize="10" TextColor="Gray"/>
                            </Grid>

                            <!--  Calendar Grid  -->
                            <CollectionView
                                HeightRequest="220"
                                ItemsSource="{Binding CalendarDays}">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="7" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="0"
                                            Margin="2"
                                            HeightRequest="40"
                                            BackgroundColor="{Binding Background}"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0"
                                            WidthRequest="40">
                                            <Label
                                                FontSize="12"
                                                HorizontalOptions="Center"
                                                Text="{Binding Day}"
                                                TextColor="White"
                                                VerticalOptions="Center" />
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" Margin="0,10,0,0">
                                <HorizontalStackLayout Spacing="5">
                                    <BoxView BackgroundColor="#10B981" CornerRadius="2" HeightRequest="8" WidthRequest="8" VerticalOptions="Center"/>
                                    <Label Text="Present" FontSize="10" TextColor="Gray"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5">
                                    <BoxView BackgroundColor="#EF4444" CornerRadius="2" HeightRequest="8" WidthRequest="8" VerticalOptions="Center"/>
                                    <Label Text="Absent" FontSize="10" TextColor="Gray"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5">
                                    <BoxView BackgroundColor="#F59E0B" CornerRadius="2" HeightRequest="8" WidthRequest="8" VerticalOptions="Center"/>
                                    <Label Text="Excused" FontSize="10" TextColor="Gray"/>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!--  Today's Schedule  -->
                    <Border Style="{StaticResource StatCard}">
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label FontAttributes="Bold" FontSize="16" Text="Today's Schedule" TextColor="White" />
                                <Label Grid.Column="1" FontSize="11" Text="{Binding CurrentDateDisplay}" TextColor="Gray" VerticalOptions="Center"/>
                            </Grid>

                            <Line Stroke="#1F2937" X2="400" StrokeThickness="1" />

                            <VerticalStackLayout IsVisible="{Binding TodaySchedule.Count, Converter={StaticResource EqualToZero}}" Padding="0,20" Spacing="10">
                                <Label Text="No classes scheduled for today." FontSize="13" TextColor="Gray" HorizontalOptions="Start"/>
                            </VerticalStackLayout>

                            <CollectionView ItemsSource="{Binding TodaySchedule}" IsVisible="{Binding TodaySchedule.Count, Converter={StaticResource NotEqualToZero}}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="15" BackgroundColor="#1F2937" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding Subject}" FontAttributes="Bold" FontSize="14" TextColor="White"/>
                                                    <HorizontalStackLayout Spacing="10">
                                                        <Label Text="{Binding Time}" FontSize="11" TextColor="Gray"/>
                                                        <Label Text="•" FontSize="11" TextColor="Gray"/>
                                                        <Label Text="{Binding Room}" FontSize="11" TextColor="#3B82F6" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                                <Button Grid.Column="1" Text="Mark" FontSize="10" HeightRequest="30" Padding="10,0" VerticalOptions="Center" IsVisible="{Binding Status, Converter={StaticResource EqualToString}, ConverterParameter='Active'}" />
                                                <Path
                                                    Grid.Column="1"
                                                    Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"
                                                    Fill="#10B981"
                                                    FontSize="18"
                                                    FontAttributes="Bold"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center"
                                                    WidthRequest="18"
                                                    HeightRequest="18"
                                                    IsVisible="{Binding Status, Converter={StaticResource EqualToString}, ConverterParameter='Completed'}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
