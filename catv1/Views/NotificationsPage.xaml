<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="catv1.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:catv1.ViewModels"
    Title="Notifications"
    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Background}}">

    <Grid RowDefinitions="Auto, *">
        <Grid Padding="24,20,24,10" ColumnDefinitions="Auto, *, Auto">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Surface}}"
                HeightRequest="40"
                Stroke="{StaticResource GlassBorder}"
                StrokeShape="RoundRectangle 20"
                WidthRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Label FontFamily="MaterialIcons" Text="&#xe5c4;" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark=White}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label
                Grid.Column="1"
                HorizontalOptions="Center"
                Style="{StaticResource LabelHeader}"
                TextColor="{AppThemeBinding Light={StaticResource Black}, Dark=White}"
                Text="Notifications"
                VerticalOptions="Center" />
        </Grid>

        <CollectionView Grid.Row="1" Margin="24,10,24,0" ItemsSource="{Binding Notifications}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                    <Label Text="No new notifications." TextColor="{StaticResource Gray400}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12" Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Surface}}" Stroke="{StaticResource GlassBorder}" StrokeShape="RoundRectangle 16">
                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                            <Label Grid.RowSpan="2" FontFamily="MaterialIcons" Text="{Binding Icon}" FontSize="24" TextColor="{StaticResource Primary}" VerticalOptions="Center" Margin="0,0,16,0" />
                            <Grid Grid.Column="1" ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Black}, Dark=White}" FontSize="16" />
                                <Label Grid.Column="1" Text="{Binding Time}" TextColor="{StaticResource Gray400}" FontSize="12" />
                            </Grid>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Message}" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" FontSize="14" Margin="0,4,0,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
